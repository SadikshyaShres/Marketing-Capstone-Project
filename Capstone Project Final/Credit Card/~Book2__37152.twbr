      <aliases enabled='yes' />
      <column caption='Avg Open To Buy' datatype='real' name='[Avg_Open_To_Buy]' role='measure' type='quantitative' />
      <column caption='Avg Utilization Ratio' datatype='real' name='[Avg_Utilization_Ratio]' role='measure' type='quantitative' />
      <column caption='Clientnum' datatype='integer' name='[CLIENTNUM]' role='measure' type='quantitative' />
      <column caption='Churn Status ' datatype='string' name='[Calculation_2553122946220032]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Churn] =1 THEN &quot;Churned&quot;&#13;&#10;ELSE &quot;Retained&quot;&#13;&#10;END' />
      </column>
      <column caption='Inactivity Group ' datatype='string' name='[Calculation_2553122946789378]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Months_Inactive_12_mon] &lt;= 1 THEN &quot;Low Inactivity&quot;&#13;&#10;ELSEIF [Months_Inactive_12_mon] &lt;= 3 THEN &quot;Moderate Inactivity&quot;&#13;&#10;ELSE &quot;High Inactivity&quot;&#13;&#10;END' />
      </column>
      <column caption='Transaction Volume Group ' datatype='string' name='[Calculation_2553122946908163]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Total_Trans_Ct] &lt; 40 THEN &quot;Low Transactions&quot;&#13;&#10;ELSEIF [Total_Trans_Ct] &lt; 80 THEN &quot;Medium Transactions&quot;&#13;&#10;ELSE &quot;High Transactions&quot;&#13;&#10;END' />
      </column>
      <column caption='Credit Limit Group ' datatype='string' name='[Calculation_2553122947018756]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Credit_Limit] &lt; 5000 THEN &quot;Low Limit&quot;&#13;&#10;ELSEIF [Credit_Limit] &lt; 10000 THEN &quot;Medium Limit&quot;&#13;&#10;ELSE &quot;High Limit&quot;&#13;&#10;END' />
      </column>
      <column caption='Age Group ' datatype='string' name='[Calculation_2553122947121157]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Customer_Age] &lt; 35 THEN &quot;Under 35&quot;&#13;&#10;ELSEIF [Customer_Age] &lt; 50 THEN &quot;35-49&quot;&#13;&#10;ELSE &quot;50+&quot;&#13;&#10;END' />
      </column>
      <column caption='Relationship Group ' datatype='string' name='[Calculation_2553122947211270]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Total_Relationship_Count] &lt;= 2 THEN &quot;Low Relationship&quot;&#13;&#10;ELSEIF [Total_Relationship_Count] &lt;= 4 THEN &quot;Medium Relationship&quot;&#13;&#10;ELSE &quot;High Relationship&quot;&#13;&#10;END' />
      </column>
      <column caption='Churn Rate' datatype='real' name='[Calculation_2553122953572360]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Churn]) / COUNTD([CLIENTNUM])' />
      </column>
      <column caption='Avg Transaction Amount' datatype='real' name='[Calculation_2553122954956810]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Total_Trans_Amt])' />
      </column>
      <column caption='Card Category' datatype='string' name='[Card_Category]' role='dimension' type='nominal' />
